<div class="container mx-auto px-4 py-8">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center space-x-4 mb-4">
        <div class="h-10 w-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center">
          <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Add New Employee</h1>
      </div>
      <p class="text-gray-600 dark:text-gray-400">Create a new employee profile for your organization</p>
    </div>
    <!-- Form -->
    <div class="modern-form">
      <%= form_with model: @employee, local: true do |form| %>
        <!-- Error Messages -->
        <% if @employee.errors.any? %>
          <div class="modern-alert modern-alert-error mb-6">
            <h3 class="font-semibold">Please fix the following errors:</h3>
            <ul class="mt-2 space-y-1">
              <% @employee.errors.full_messages.each do |message| %>
                <li>• <%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="modern-form-group">
            <%= form.label :username, "Username", class: "modern-label" %>
            <%= form.text_field :username, class: "modern-input", placeholder: "Enter username" %>
          </div>
          <div class="modern-form-group">
            <%= form.label :email, "Email Address", class: "modern-label" %>
            <%= form.email_field :email, class: "modern-input", placeholder: "Enter email address" %>
          </div>
        </div>
        <div class="modern-form-group">
          <%= form.label :title, "Job Title", class: "modern-label" %>
          <%= form.text_field :title, class: "modern-input", placeholder: "Enter job title" %>
        </div>
        <div class="modern-form-group">
          <%= form.label :address, "Address", class: "modern-label" %>
          <%= form.text_area :address, rows: 3, class: "modern-textarea", placeholder: "Enter address" %>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="modern-form-group">
            <label class="modern-label">Reports To (Supervisor)</label>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Drag a supervisor from available list (optional)</p>
            <div data-controller="drag-drop-assign" 
                 data-drag-drop-assign-field-name-value="employee[parent_id]"
                 data-drag-drop-assign-initial-assigned-value="<%= @employee.parent_id ? [@employee.parent_id].to_json : [].to_json %>">
              <!-- Search for available supervisors -->
              <div class="assignment-search">
                <svg class="search-icon h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <input type="text" 
                       data-drag-drop-assign-target="searchInput"
                       placeholder="Search potential supervisors..." 
                       class="modern-input">
                <button type="button" 
                        data-action="click->drag-drop-assign#clearSearch"
                  data-drag-drop-assign-target="clearSearch"
                  class="clear-search hidden">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </button>
              </div>
              <div class="drag-drop-container">
                <!-- Available Supervisors -->
                <div class="assignment-column">
                  <div class="assignment-column-header">
                    <span>Available Supervisors</span>
                    <span class="assignment-count"><%= @potential_parents.count %></span>
                  </div>
                  <div data-drag-drop-assign-target="availableList">
                    <% if @potential_parents.any? %>
                      <% @potential_parents.each do |supervisor| %>
                        <div class="assignable-item" 
                             data-id="<%= supervisor.id %>"
                             data-search-text="<%= "#{supervisor.username} #{supervisor.title}".downcase %>">
                          <div class="avatar">
                            <%= supervisor.username.first.upcase %>
                          </div>
                          <div class="info">
                            <div class="name"><%= supervisor.username %></div>
                            <div class="title"><%= supervisor.title %></div>
                          </div>
                        </div>
                      <% end %>
                    <% else %>
                      <div class="assignment-empty">
                        <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                        </svg>
                        <div class="text">No potential supervisors</div>
                      </div>
                    <% end %>
                  </div>
                </div>
                <!-- Selected Supervisor -->
                <div class="assignment-column">
                  <div class="assignment-column-header">
                    <span>Selected Supervisor</span>
                    <span class="assignment-count">0</span>
                  </div>
                  <div data-drag-drop-assign-target="assignedList">
                    <div class="assignment-empty">
                      <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                      <div class="text">Drag a supervisor here (optional)</div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Hidden inputs container -->
              <div data-drag-drop-assign-target="hiddenInput"></div>
            </div>
          </div>
          <div class="modern-form-group">
            <%= form.label :position, "Position (Hierarchy Order)", class: "modern-label" %>
            <%= form.number_field :position, class: "modern-input", placeholder: "Enter position number" %>
          </div>
        </div>
        <div class="flex justify-between pt-6">
          <%= link_to "Cancel", employees_path, class: "modern-btn modern-btn-secondary" %>
          <%= form.submit "Create Employee", class: "modern-btn modern-btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
