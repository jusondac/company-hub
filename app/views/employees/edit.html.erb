<div class="container mx-auto px-4 py-8">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center space-x-4 mb-4">
        <div class="h-10 w-10 bg-gradient-to-br from-green-500 to-blue-600 rounded-lg flex items-center justify-center">
          <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Edit Employee</h1>
      </div>
      <p class="text-gray-600 dark:text-gray-400">Update employee information and organizational structure</p>
    </div>
    <!-- Form -->
    <div class="modern-form">
      <%= form_with model: @employee, local: true do |form| %>
        <!-- Error Messages -->
        <% if @employee.errors.any? %>
          <div class="modern-alert modern-alert-error mb-6">
            <h3 class="font-semibold">Please fix the following errors:</h3>
            <ul class="mt-2 space-y-1">
              <% @employee.errors.full_messages.each do |message| %>
                <li>• <%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="modern-form-group">
            <%= form.label :username, "Username", class: "modern-label" %>
            <%= form.text_field :username, class: "modern-input", placeholder: "Enter username" %>
          </div>
          <div class="modern-form-group">
            <%= form.label :email, "Email Address", class: "modern-label" %>
            <%= form.email_field :email, class: "modern-input", placeholder: "Enter email address" %>
          </div>
        </div>
        <div class="modern-form-group">
          <%= form.label :title, "Job Title", class: "modern-label" %>
          <%= form.text_field :title, class: "modern-input", placeholder: "Enter job title" %>
        </div>
        <div class="modern-form-group">
          <%= form.label :address, "Address", class: "modern-label" %>
          <%= form.text_area :address, rows: 3, class: "modern-textarea", placeholder: "Enter address" %>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="modern-form-group">
            <%= form.label :parent_id, "Reports To (Supervisor)", class: "modern-label" %>
            <%= form.select :parent_id, 
                options_from_collection_for_select(@potential_parents, :id, :username, @employee.parent_id), 
                { prompt: "Select a supervisor (optional)" },
                { class: "modern-select" } %>
          </div>
          <div class="modern-form-group">
            <%= form.label :position, "Position (Hierarchy Order)", class: "modern-label" %>
            <%= form.number_field :position, class: "modern-input", placeholder: "Enter position number" %>
          </div>
        </div>
        <div class="flex justify-between pt-6">
          <%= link_to "Cancel", employee_path(@employee), class: "modern-btn modern-btn-secondary" %>
          <%= form.submit "Update Employee", class: "modern-btn modern-btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
