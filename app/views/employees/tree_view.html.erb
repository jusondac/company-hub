<div class="container mx-auto px-6 py-8 max-w-full">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Employee Organizational Tree</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Visualize your organization's hierarchy</p>
    </div>
    <div class="flex gap-3">
      <%= link_to employees_path, class: "px-4 py-2 font-medium rounded-lg hover:bg-gray-100 bg-gray-50 border border-gray-300 inline-flex items-center gap-2 text-gray-700" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
        </svg>
        List View
      <% end %>
      <%= link_to new_employee_path, class: "px-4 py-2 font-bold rounded-lg hover:bg-blue-800 bg-blue-700 text-white inline-flex items-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Add Employee
      <% end %>
    </div>
  </div>
  <!-- Tree Chart Container -->
  <div class="grid grid-cols-1 xl:grid-cols-2 gap-8 mb-8">
    <!-- Network Chart -->
    <div class="modern-card">
      <div class="p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Network Structure</h2>
          <div class="flex items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
              <span>Level 0</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
              <span>Level 1</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
              <span>Level 2+</span>
            </div>
          </div>
        </div>
        <div 
          data-controller="network-chart"
          class="w-full" >
          <div data-network-chart-target="chart" class="w-full" id="svg-tree"></div>
        </div>
      </div>
    </div>
  </div>
</div>