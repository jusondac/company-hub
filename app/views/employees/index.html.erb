<div class="container mx-auto px-6 py-8 max-w-full">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Employees</h1>
      <p class="text-gray-600 dark:text-gray-400 mt-1">Manage your organization's workforce</p>
    </div>
    <div class="flex gap-3">
      <%= link_to tree_view_employees_path, class: "px-4 py-2 font-medium rounded-lg hover:bg-purple-100 bg-purple-50 border border-purple-300 inline-flex items-center gap-2 text-purple-700" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h1.586a1 1 0 01.707.293l1.414 1.414a1 1 0 00.707.293H19a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
        </svg>
        Tree View
      <% end %>
      <%= link_to new_employee_path, class: "px-4 py-2 font-bold rounded-lg hover:bg-blue-800 bg-blue-700 text-white inline-flex items-center gap-2" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Add Employee
      <% end %>
    </div>
  </div>
  <!-- Employees Table -->
  <div class="modern-card p-0 overflow-hidden border rounded-lg border-gray-600">
    <div class="py-4 bg-gray-50 dark:bg-gray-800 px-10 border-b border-gray-200 dark:border-gray-700">
      <%= search_form_for @q, url: employees_path, method: :get, html: { class: "flex flex-col sm:flex-row gap-3 items-start sm:items-center" } do |f| %>
        <div class="flex gap-2 flex-1">
          <%= f.label :username_or_email_cont, "Search", class: "sr-only" %>
          <%= f.text_field :username_or_email_cont, placeholder: "Search by name or email...", class: "form-input w-full rounded-lg border border-gray-700 dark:bg-gray-900 dark:text-white px-4 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none" %>
        </div>
        <div>
          <%= f.submit "Search", class: "px-6 py-2 rounded-lg font-semibold bg-gradient-to-r from-blue-500 to-purple-600 text-white shadow-sm hover:from-blue-600 hover:to-purple-700 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-blue-400" %>
        </div>
      <% end %>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-300 uppercase tracking-wider">Employee</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-300 uppercase tracking-wider">Contact</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-300 uppercase tracking-wider">Reports To</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-300 uppercase tracking-wider">Hierarchy</th>
            <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700"
               data-controller="sortable" 
               data-sortable-url-value="<%= sort_position_employees_path %>"
               data-sortable-handle-value=".drag-handle"
               data-sortable-target="list">
          <% @employees.each do |employee| %>
            <tr data-id="<%= employee.id %>" class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-150">
              <!-- Employee Info -->
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="h-10 w-10 flex-shrink-0">
                    <div class="h-10 w-10 rounded-full bg-gradient-to-r from-blue-500 to-purple-600 flex items-center justify-center">
                      <span class="text-sm font-medium text-white">
                        <%= employee.username.first(2).upcase %>
                      </span>
                    </div>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-semibold text-gray-900 dark:text-white">
                      <%= employee.username %>
                    </div>
                    <div class="text-sm text-gray-500 dark:text-gray-400">
                      <%= employee.title %>
                    </div>
                  </div>
                </div>
              </td>
              <!-- Contact Info -->
              <td class="px-6 py-4">
                <div class="text-sm text-gray-900 dark:text-white">
                  <%= employee.email %>
                </div>
                <div class="text-sm text-gray-500 dark:text-gray-400 truncate max-w-xs">
                  <%= employee.address %>
                </div>
              </td>
              <!-- Reports To -->
              <td class="px-6 py-4 whitespace-nowrap">
                <% if employee.parent.present? %>
                  <div class="flex items-center">
                    <div class="h-8 w-8 flex-shrink-0">
                      <div class="h-8 w-8 rounded-full bg-gradient-to-r from-green-500 to-teal-600 flex items-center justify-center">
                        <span class="text-xs font-medium text-white">
                          <%= employee.parent.username.first(2).upcase %>
                        </span>
                      </div>
                    </div>
                    <div class="ml-3">
                      <div class="text-sm text-gray-900 dark:text-white">
                        <%= employee.parent.username %>
                      </div>
                      <div class="text-xs text-gray-500 dark:text-gray-400">
                        <%= employee.parent.title %>
                      </div>
                    </div>
                  </div>
                <% else %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                    Root Level
                  </span>
                <% end %>
              </td>
              <!-- Hierarchy Level -->
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div class="flex-1 bg-gray-200 dark:bg-gray-600 rounded-full h-2 mr-3">
                    <div class="h-2 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full transition-all duration-300" 
                         style="width: <%= [100, (employee.hierarchy_level + 1) * 25].min %>%"></div>
                  </div>
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                    Level <%= employee.hierarchy_level %>
                  </span>
                </div>
              </td>
              <!-- Actions -->
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex justify-end gap-3">
                  <%= link_to employee_path(employee), class: "text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                    </svg>
                  <% end %>
                  <%= link_to edit_employee_path(employee), class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                  <% end %>
                  <%= link_to employee_path(employee), method: :delete, 
                              data: { confirm: "Are you sure you want to delete this employee?" }, 
                              class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <!-- Empty State -->
    <% if @employees.empty? %>
      <div class="text-center py-12">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No employees found</h3>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by adding your first employee.</p>
        <div class="mt-6">
          <%= link_to "Add Employee", new_employee_path, class: "btn-primary" %>
        </div>
      </div>
    <% end %>
    <%= render 'shared/pagination', pagy: @pagy %>
  </div>
</div>
