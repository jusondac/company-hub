<div class="employee-node level-<%= level %> mb-4">
  <div class="flex items-center p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md transition-shadow">
    <!-- Employee Avatar -->
    <div class="flex-shrink-0 mr-4">
      <div class="w-12 h-12 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white font-bold text-lg">
        <%= employee.username.first.upcase %>
      </div>
    </div>
    <!-- Employee Info -->
    <div class="flex-grow">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
            <%= employee.username %>
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            <%= employee.title %>
          </p>
          <p class="text-xs text-gray-500 dark:text-gray-500">
            Position: <%= employee.position %> | <%= employee.email %>
          </p>
        </div>
        <!-- Level Badge -->
        <div class="flex items-center gap-2">
          <span class="px-2 py-1 text-xs font-medium rounded-full 
            <%= case level
                when 0 then 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200'
                when 1 then 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                when 2 then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
                else 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                end %>">
            Level <%= level %>
          </span>
          <!-- Children Count -->
          <% if employee.children.any? %>
            <span class="px-2 py-1 text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200 rounded-full">
              <%= employee.children.count %> reports
            </span>
          <% end %>
          <!-- Action Buttons -->
          <div class="flex gap-1">
            <%= link_to employee_path(employee), class: "p-1 text-gray-500 hover:text-blue-600 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            <% end %>
            <%= link_to edit_employee_path(employee), class: "p-1 text-gray-500 hover:text-green-600 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <!-- Render Children -->
  <% if employee.children.any? %>
    <div class="mt-4 ml-6 space-y-4">
      <% employee.children.each do |child| %>
        <%= render 'employee_node', employee: child, level: level + 1 %>
      <% end %>
    </div>
  <% end %>
</div>
