<div class="container mx-auto px-6 py-8">
  <div class="max-w-5xl mx-auto">
    <!-- Header Card -->
    <div class="modern-card mb-8">
      <div class="bg-gradient-to-r from-purple-500 to-pink-600 text-white p-8 rounded-t-xl">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div>
            <h1 class="text-4xl font-bold mb-2"><%= @task.title %></h1>
            <div class="flex items-center text-purple-100">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
              Board: <%= link_to @board.name, board_path(@board), class: "text-purple-100 hover:text-white underline font-medium" %>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row gap-3">
            <%= link_to edit_board_task_path(@board, @task), class: "modern-btn-white" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
              Edit Task
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Task Details -->
      <div class="lg:col-span-2">
        <div class="modern-card">
          <div class="p-6">
            <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6 flex items-center">
              <svg class="w-6 h-6 mr-3 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              Task Details
            </h2>
            <div class="space-y-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Description</label>
                <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 border border-gray-200 dark:border-gray-700">
                  <p class="text-gray-900 dark:text-white leading-relaxed"><%= @task.description %></p>
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Position</label>
                  <div class="modern-badge bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300 inline-flex">
                    #<%= @task.position %>
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Status</label>
                  <div class="modern-badge bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300 inline-flex">
                    Active
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- Assigned Employees -->
        <div class="modern-card mt-6">
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6 flex items-center">
              <svg class="w-5 h-5 mr-3 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              Assigned Employees
              <span class="ml-2 text-sm font-normal text-gray-500 dark:text-gray-400">(<%= @task.employees.count %>)</span>
            </h3>
            <% if @task.employees.any? %>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% @task.employees.each do |employee| %>
                  <div class="bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-xl p-4 hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center">
                          <span class="text-white text-sm font-bold">
                            <%= employee.username.first(2).upcase %>
                          </span>
                        </div>
                        <div>
                          <h4 class="font-semibold text-gray-900 dark:text-white"><%= employee.username %></h4>
                          <p class="text-sm text-gray-600 dark:text-gray-400"><%= employee.title %></p>
                          <p class="text-xs text-gray-500 dark:text-gray-500"><%= employee.email %></p>
                        </div>
                      </div>
                      <%= link_to employee_path(employee), class: "text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 transition-colors" do %>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                        </svg>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-8">
                <div class="w-12 h-12 mx-auto mb-3 bg-yellow-100 dark:bg-yellow-900/30 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.464 0L4.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                  </svg>
                </div>
                <p class="text-yellow-800 dark:text-yellow-200 font-medium">No employees assigned</p>
                <p class="text-yellow-600 dark:text-yellow-400 text-sm mt-1">This task is currently unassigned</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <!-- Board Information -->
        <div class="modern-card">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
              Board Information
            </h3>
            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-4">
              <h4 class="font-semibold text-blue-900 dark:text-blue-100 mb-2"><%= @board.name %></h4>
              <p class="text-sm text-blue-700 dark:text-blue-300 mb-4 leading-relaxed">
                <%= truncate(@board.description, length: 120) %>
              </p>
              <div>
                <span class="text-xs font-medium text-blue-600 dark:text-blue-400 uppercase tracking-wide">Board Managers:</span>
                <div class="flex flex-wrap gap-1 mt-2">
                  <% @board.employees.each do |manager| %>
                    <div class="modern-badge bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 text-xs">
                      <%= manager.username %>
                    </div>
                  <% end %>
                </div>
              </div>
              <div class="mt-4 pt-4 border-t border-blue-200 dark:border-blue-700">
                <%= link_to board_path(@board), class: "text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 text-sm font-medium flex items-center" do %>
                  View Full Board
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        </div>
        <!-- Actions -->
        <div class="modern-card mt-6">
          <div class="p-6">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
              </svg>
              Actions
            </h3>
            <div class="space-y-3">
              <%= link_to edit_board_task_path(@board, @task), class: "modern-btn-primary w-full justify-center" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Edit Task
              <% end %>
              <%= link_to board_task_path(@board, @task), method: :delete, 
                          data: { confirm: "Are you sure you want to delete this task?" }, 
                          class: "modern-btn-danger w-full justify-center" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Delete Task
              <% end %>
              <%= link_to board_path(@board), class: "modern-btn-secondary w-full justify-center" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Back to Board
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
