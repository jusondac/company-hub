<!-- Modal Header -->
<div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-700">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-gradient-to-r from-purple-500 to-pink-600 rounded-lg flex items-center justify-center">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
      </svg>
    </div>
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @task.title %></h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">Task Details</p>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <button data-modal-target="task-edit-modal" data-modal-toggle="task-edit-modal" 
            data-task-id="<%= @task.id %>"
            onclick="loadTaskForm(<%= @task.id %>); document.querySelector('[data-modal-hide=task-detail-modal]').click();"
            class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors flex items-center text-sm">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
      </svg>
      Edit
    </button>
    <button data-modal-hide="task-detail-modal"
            class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</div>
<!-- Modal Content -->
<div class="p-6 max-h-[calc(90vh-120px)] overflow-y-auto">
  <div class="space-y-6">
    <!-- Task Description -->
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Description</label>
      <div class="bg-gray-50 dark:bg-gray-800 rounded-xl p-4 border border-gray-200 dark:border-gray-700">
        <p class="text-gray-900 dark:text-white leading-relaxed">
          <%= @task.description.present? ? @task.description : "No description provided." %>
        </p>
      </div>
    </div>
    <!-- Task Metadata -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Position & Card -->
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Position</label>
          <div class="bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300 inline-flex items-center px-3 py-1 rounded-full text-sm font-medium">
            #<%= @task.position %>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Priority</label>
          <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium 
                      <%= case @task.priority&.downcase
                          when 'critical' then 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300'
                          when 'high' then 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300'
                          when 'medium' then 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300'
                          else 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300'
                          end %>">
            <%= @task.priority || 'Low' %>
          </div>
        </div>
        <% if @task.card %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Card</label>
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full" style="background-color: <%= @task.card.color || '#6366f1' %>;"></div>
              <span class="text-gray-900 dark:text-white font-medium"><%= @task.card.title %></span>
            </div>
          </div>
        <% end %>
      </div>
      <!-- Timestamps -->
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Created</label>
          <div class="text-gray-900 dark:text-white">
            <%= @task.created_at.strftime("%B %d, %Y at %I:%M %p") %>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Last Updated</label>
          <div class="text-gray-900 dark:text-white">
            <%= @task.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
          </div>
        </div>
      </div>
    </div>
    <!-- Assigned Employees -->
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Assigned Team Members</label>
      <% if @task.employees.any? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% @task.employees.each do |employee| %>
            <div class="flex items-center space-x-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
              <div class="w-8 h-8 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center">
                <span class="text-white text-xs font-bold">
                  <%= employee.username.first(2).upcase %>
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="font-medium text-gray-900 dark:text-white text-sm truncate"><%= employee.username %></h4>
                <p class="text-xs text-gray-600 dark:text-gray-400 truncate"><%= employee.title %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="w-12 h-12 mx-auto mb-3 bg-gray-200 dark:bg-gray-700 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <p class="text-gray-500 dark:text-gray-400 text-sm">No team members assigned</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
