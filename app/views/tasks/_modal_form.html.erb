<!-- Modal Header -->
<div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-700">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-gradient-to-r from-green-500 to-blue-600 rounded-lg flex items-center justify-center">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
      </svg>
    </div>
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @task.persisted? ? 'Edit Task' : 'Create New Task' %></h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        <%= @task.persisted? ? 'Update task details and assignments' : 'Add a new task to your board' %>
      </p>
    </div>
  </div>
  <button data-modal-hide="task-edit-modal"
          class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>
<!-- Modal Content -->
<div class="p-6">
  <%= form_with(model: [@board, @task], 
                local: true, 
                class: "space-y-6") do |form| %>
    <% if @task.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
              <%= pluralize(@task.errors.count, "error") %> prohibited this task from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700 dark:text-red-300">
              <ul class="list-disc list-inside space-y-1">
                <% @task.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>
    <!-- Task Title -->
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
      <%= form.text_field :title, 
                          class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors",
                          placeholder: "Enter task title..." %>
    </div>
    <!-- Task Description -->
    <div>
      <%= form.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
      <%= form.text_area :description, 
                         rows: 4,
                         class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors",
                         placeholder: "Enter task description..." %>
    </div>
    <!-- Card Selection and Position -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <%= form.label :card_id, "Card", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= form.select :card_id, 
                        options_from_collection_for_select(@board.cards.ordered_by_position, :id, :title, @task.card_id || params[:card_id]),
                        { prompt: "Select a card..." },
                        { class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors" } %>
      </div>
      <div>
        <%= form.label :priority, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= form.select :priority, 
                        options_for_select([
                          ['Low', 'Low'],
                          ['Medium', 'Medium'], 
                          ['High', 'High'],
                          ['Critical', 'Critical']
                        ], @task.priority || 'Low'),
                        {},
                        { class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors" } %>
      </div>
      <div>
        <%= form.label :position, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
        <%= form.number_field :position, 
                              class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors",
                              placeholder: "Position (optional)" %>
      </div>
    </div>
    <!-- Employee Assignment -->
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Assign Team Members</label>
      <div data-controller="drag-drop-assign"
           data-drag-drop-assign-field-name-value="task[employee_ids][]"
           data-drag-drop-assign-initial-assigned-value="<%= @task.employee_ids.to_json %>"
           class="bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
        <!-- Search -->
        <div class="mb-4">
          <div class="relative">
            <input type="text" 
                   data-drag-drop-assign-target="searchInput"
                   placeholder="Search employees..."
                   class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white text-sm">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <!-- Available Employees -->
          <div class="assignment-column">
            <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Available (<span class="assignment-count"><%= @board.employees.count %></span>)
            </h4>
            <div data-drag-drop-assign-target="availableList" 
                 class="min-h-[120px] max-h-40 overflow-y-auto space-y-2 p-2 bg-white dark:bg-gray-700 rounded border-2 border-dashed border-gray-300 dark:border-gray-600">
              <% @board.employees.each do |employee| %>
                <div class="assignment-item flex items-center space-x-2 p-2 bg-gray-50 dark:bg-gray-800 rounded cursor-move hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                     data-id="<%= employee.id %>"
                     data-search-text="<%= employee.username.downcase %> <%= employee.title.downcase %>">
                  <div class="w-6 h-6 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full flex items-center justify-center">
                    <span class="text-white text-xs font-bold">
                      <%= employee.username.first.upcase %>
                    </span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-gray-900 dark:text-white truncate"><%= employee.username %></div>
                    <div class="text-xs text-gray-600 dark:text-gray-400 truncate"><%= employee.title %></div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
          <!-- Assigned Employees -->
          <div class="assignment-column">
            <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
              Assigned (<span class="assignment-count">0</span>)
            </h4>
            <div data-drag-drop-assign-target="assignedList" 
                 class="min-h-[120px] max-h-40 overflow-y-auto space-y-2 p-2 bg-white dark:bg-gray-700 rounded border-2 border-dashed border-gray-300 dark:border-gray-600">
              <div class="assignment-empty flex flex-col items-center justify-center py-4 text-gray-400 dark:text-gray-500">
                <svg class="w-8 h-8 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                <span class="text-sm">Drag employees here</span>
              </div>
            </div>
          </div>
        </div>
        <!-- Hidden inputs for form submission -->
        <div data-drag-drop-assign-target="hiddenInput"></div>
      </div>
    </div>
    <!-- Form Actions -->
    <div class="flex items-center justify-between pt-6 border-t border-gray-200 dark:border-gray-700">
      <button type="button" 
              data-modal-hide="task-edit-modal"
              class="bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 font-semibold py-3 px-6 rounded-lg transition-colors">
        Cancel
      </button>
      <div class="flex gap-3">
        <% if @task.persisted? %>
          <%= link_to board_task_path(@board, @task), 
                      method: :delete, 
                      data: { confirm: "Are you sure you want to delete this task?" },
                      class: "bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors" do %>
            Delete Task
          <% end %>
        <% end %>
        <button type="submit" 
                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <%= @task.persisted? ? 'Update Task' : 'Create Task' %>
        </button>
      </div>
    </div>
  <% end %>
</div>
