<!-- Modal Header -->
<div class="flex items-center justify-between p-6 border-b border-gray-200 dark:border-gray-700">
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 bg-gradient-to-r from-purple-500 to-pink-600 rounded-lg flex items-center justify-center">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
      </svg>
    </div>
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @card.persisted? ? 'Edit Card' : 'Create New Card' %></h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        <%= @card.persisted? ? 'Update card details and appearance' : 'Add a new card to organize your tasks' %>
      </p>
    </div>
  </div>
  <button data-action="click->modal#hide" 
    class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>
<!-- Modal Content -->
<div class="p-6">
  <%= form_with(model: [@board, @card], 
                local: true, 
                data: { action: "submit->modal#submitForm" },
                class: "space-y-6") do |form| %>
    <% if @card.errors.any? %>
      <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
              <%= pluralize(@card.errors.count, "error") %> prohibited this card from being saved:
            </h3>
            <div class="mt-2 text-sm text-red-700 dark:text-red-300">
              <ul class="list-disc list-inside space-y-1">
                <% @card.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>
    <!-- Card Title -->
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
      <%= form.text_field :title, 
                          class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors",
                          placeholder: "Enter card title..." %>
    </div>
    <!-- Color Selection -->
    <div>
      <%= form.label :color, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-3" %>
      <div class="grid grid-cols-8 gap-3">
        <% %w[#6366f1 #8b5cf6 #ec4899 #ef4444 #f59e0b #10b981 #06b6d4 #6b7280].each do |color| %>
          <label class="relative cursor-pointer">
            <%= form.radio_button :color, color, class: "sr-only peer", checked: (@card.color == color) %>
            <div class="w-10 h-10 rounded-lg border-2 border-gray-300 dark:border-gray-600 peer-checked:border-gray-900 dark:peer-checked:border-white peer-checked:ring-2 peer-checked:ring-offset-2 peer-checked:ring-blue-500 transition-all"
                 style="background-color: <%= color %>;">
              <div class="w-full h-full rounded-md opacity-0 peer-checked:opacity-100 flex items-center justify-center transition-opacity">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
            </div>
          </label>
        <% end %>
      </div>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">Choose a color to help identify this card</p>
    </div>
    <!-- Position -->
    <div>
      <%= form.label :position, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
      <%= form.number_field :position, 
                            class: "w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-gray-700 dark:text-white transition-colors",
                            placeholder: "Position (leave empty for automatic positioning)" %>
      <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Lower numbers appear first. Leave empty to add at the end.</p>
    </div>
    <!-- Form Actions -->
    <div class="flex items-center justify-between pt-6 border-t border-gray-200 dark:border-gray-700">
      <button type="button" 
              data-action="click->modal#hide"
        class="bg-gray-200 hover:bg-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 font-semibold py-3 px-6 rounded-lg transition-colors">
        Cancel
      </button>
      <div class="flex gap-3">
        <% if @card.persisted? %>
          <%= link_to board_card_path(@board, @card), 
                      method: :delete, 
                      data: { confirm: "Are you sure? This will move all tasks to the first card." },
                      class: "bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors" do %>
            Delete Card
          <% end %>
        <% end %>
        <button type="submit" 
                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors flex items-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <%= @card.persisted? ? 'Update Card' : 'Create Card' %>
        </button>
      </div>
    </div>
  <% end %>
</div>
