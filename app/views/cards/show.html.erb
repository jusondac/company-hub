<div class="container mx-auto px-6 py-8">
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <%= link_to board_path(@board), class: "text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
      <% end %>
      <nav class="flex" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-gray-500 dark:text-gray-400">
          <li>
            <%= link_to "Boards", boards_path, class: "hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <%= link_to @board.name, board_path(@board), class: "hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-gray-900 dark:text-white font-medium"><%= @card.title %></span>
          </li>
        </ol>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: <%= @card.color %>;">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
        </svg>
      </div>
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white"><%= @card.title %></h1>
        <p class="text-gray-600 dark:text-gray-400">Card position: <%= @card.position %> | <%= @card.tasks.count %> tasks</p>
      </div>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Card Stats -->
    <div class="lg:col-span-1">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 p-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Card Information</h2>
        <div class="space-y-4">
          <div>
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Title</label>
            <p class="text-gray-900 dark:text-white"><%= @card.title %></p>
          </div>
          <div>
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Color</label>
            <div class="flex items-center gap-2 mt-1">
              <div class="w-6 h-6 rounded" style="background-color: <%= @card.color %>;"></div>
              <span class="text-gray-900 dark:text-white"><%= @card.color %></span>
            </div>
          </div>
          <div>
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Position</label>
            <p class="text-gray-900 dark:text-white"><%= @card.position %></p>
          </div>
          <div>
            <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Total Tasks</label>
            <p class="text-gray-900 dark:text-white"><%= @card.tasks.count %></p>
          </div>
        </div>
        <div class="flex gap-2 mt-6">
          <%= link_to edit_board_card_path(@board, @card), 
                      class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors flex items-center" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Edit Card
          <% end %>
        </div>
      </div>
    </div>
    <!-- Tasks in this Card -->
    <div class="lg:col-span-2">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700">
        <div class="p-6 border-b border-gray-200 dark:border-gray-700">
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Tasks in this Card</h2>
        </div>
        <div class="p-6">
          <% if @card.tasks.any? %>
            <div class="space-y-4">
              <% @card.tasks.ordered_by_position.each do |task| %>
                <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 border border-gray-200 dark:border-gray-600">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <h3 class="font-medium text-gray-900 dark:text-white text-sm flex-1"><%= task.title %></h3>
                    <div class="flex items-center gap-1">
                      <%= link_to board_task_path(@board, task), class: "p-1 text-gray-400 hover:text-blue-500 transition-colors" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                      <% end %>
                      <%= link_to edit_board_task_path(@board, task), class: "p-1 text-gray-400 hover:text-green-500 transition-colors" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                      <% end %>
                    </div>
                  </div>
                  <% if task.description.present? %>
                    <p class="text-gray-600 dark:text-gray-400 text-xs mb-3"><%= truncate(task.description, length: 150) %></p>
                  <% end %>
                  <div class="flex items-center justify-between">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-200 text-gray-700 dark:bg-gray-600 dark:text-gray-300">
                      Position: <%= task.position %>
                    </span>
                    <% if task.employees.any? %>
                      <div class="flex items-center gap-1">
                        <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                        <span class="text-xs text-gray-500 dark:text-gray-400"><%= task.employees.count %> assigned</span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-8">
              <div class="w-12 h-12 mx-auto mb-3 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
              </div>
              <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-1">No tasks yet</h3>
              <p class="text-gray-500 dark:text-gray-400 mb-4">This card doesn't have any tasks assigned to it.</p>
              <%= link_to new_board_task_path(@board, card_id: @card.id), 
                          class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors inline-flex items-center" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Add First Task
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
