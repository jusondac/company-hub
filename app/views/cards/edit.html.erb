<div class="container mx-auto px-6 py-8">
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-4">
      <%= link_to board_path(@board), class: "text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
      <% end %>
      <nav class="flex" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-gray-500 dark:text-gray-400">
          <li>
            <%= link_to "Boards", boards_path, class: "hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <%= link_to @board.name, board_path(@board), class: "hover:text-gray-700 dark:hover:text-gray-300 transition-colors" %>
          </li>
          <li class="flex items-center">
            <svg class="w-4 h-4 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
            <span class="text-gray-900 dark:text-white font-medium">Edit Card</span>
          </li>
        </ol>
      </nav>
    </div>
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: <%= @card.color %>;">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
        </svg>
      </div>
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Edit Card: <%= @card.title %></h1>
        <p class="text-gray-600 dark:text-gray-400">Update card settings and organization</p>
      </div>
    </div>
  </div>
  <div class="max-w-2xl">
    <%= render 'form', card: @card %>
  </div>
  <!-- Danger Zone -->
  <div class="max-w-2xl mt-8">
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-6">
      <h3 class="text-lg font-semibold text-red-800 dark:text-red-400 mb-2">Danger Zone</h3>
      <p class="text-red-700 dark:text-red-300 mb-4">
        Deleting this card will move all its tasks to the first card on the board. This action cannot be undone.
      </p>
      <%= link_to board_card_path(@board, @card), 
                  method: :delete, 
                  data: { confirm: "Are you sure you want to delete this card? All tasks will be moved to the first card." },
                  class: "bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
        Delete Card
      <% end %>
    </div>
  </div>
</div>
