<% @tasks&.each do |task| %>
  <div id="detail-modal-<%= task.id %>" data-modal-backdrop="static" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 flex justify-center items-center w-full h-screen bg-gray-900/60 backdrop-blur-sm">
    <div class="relative w-full max-w-xl mx-auto p-2">
      <!-- Modal content -->
      <div class="relative bg-white dark:bg-gray-800 rounded-xl shadow-xl overflow-hidden transform transition-all border border-gray-100 dark:border-gray-700">
        <!-- Modal header with gradient background -->
        <div class="<%= case task.priority
                when 'Low' then 'bg-gradient-to-r from-blue-500 to-cyan-400'
                when 'Medium' then 'bg-gradient-to-r from-yellow-400 to-amber-500'
                when 'High' then 'bg-gradient-to-r from-orange-500 to-red-400'
                when 'Critical' then 'bg-gradient-to-r from-red-500 to-pink-600'
                else 'bg-gradient-to-r from-indigo-500 to-purple-600'
                end %> p-6">
          <div class="flex items-center justify-between">
            <div>
              <h3 class="text-xl font-medium text-white drop-shadow-sm">
                <%= task.title %>
              </h3>
              <div class="flex items-center mt-1">
                <% if task.priority.present? %>
                  <span class="px-2.5 py-1 text-xs font-semibold rounded-full bg-white/20 text-white backdrop-blur-sm flex items-center gap-1.5">
                    <% 
                      priority_icon = case task.priority
                        when 'Low' then '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118l-2.8-2.034c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>'
                        when 'Medium' then '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path></svg>'
                        when 'High' then '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>'
                        when 'Critical' then '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"></path></svg>'
                      end
                    %>
                    <%= priority_icon.html_safe %>
                    <%= task.priority %>
                  </span>
                <% end %>
                <span class="ml-3 text-xs text-white/80">Task #<%= task.id %></span>
              </div>
            </div>
            <button type="button" class="text-white/80 hover:text-white transition-colors p-1.5 rounded-full hover:bg-white/10" data-modal-hide="detail-modal-<%= task.id %>">
              <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span class="sr-only">Close modal</span>
            </button>
          </div>
        </div>
        <!-- Task metadata area -->
        <div class="px-6 py-3 bg-gray-50 dark:bg-gray-700/30 border-b border-gray-100 dark:border-gray-700 flex flex-wrap gap-4">
          <div class="flex items-center text-sm">
            <svg class="w-4 h-4 mr-1.5 text-gray-500 dark:text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-gray-600 dark:text-gray-300"><%= task.created_at&.strftime("%b %d, %Y") || "No date" %></span>
          </div>
          <% if task.board %>
            <div class="flex items-center text-sm">
              <svg class="w-4 h-4 mr-1.5 text-gray-500 dark:text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path fill-rule="evenodd" d="M5 4a3 3 0 00-3 3v6a3 3 0 003 3h10a3 3 0 003-3V7a3 3 0 00-3-3H5zm-1 9v-1h5v2H5a1 1 0 01-1-1zm7 1h4a1 1 0 001-1v-1h-5v2zm0-4h5V8h-5v2zM9 8H4v2h5V8z" clip-rule="evenodd"></path>
              </svg>
              <span class="text-gray-600 dark:text-gray-300"><%= task.board.name %></span>
            </div>
          <% end %>
        </div>
        <!-- Modal body -->
        <div class="px-6 py-6 space-y-6">
          <div class="prose dark:prose-invert max-w-none">
            <p class="text-gray-700 dark:text-gray-200 leading-relaxed"><%= task.description %></p>
          </div>
          <% if task.employees.any? %>
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700">
              <h4 class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-3 flex items-center">
                <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path>
                </svg>
                Assigned to
              </h4>
              <div class="flex flex-wrap gap-2">
                <% task.employees.each do |employee| %>
                  <div class="inline-flex items-center px-3 py-1.5 rounded-full text-sm bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-600">
                    <span class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300 flex items-center justify-center text-xs font-medium mr-1.5">
                      <%= employee.username.first.upcase %>
                    </span>
                    <%= employee.username %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <!-- Modal footer -->
        <div class="flex justify-end gap-3 px-6 py-4 bg-gray-50 dark:bg-gray-900 border-t border-gray-100 dark:border-gray-700">
          <button data-modal-hide="detail-modal-<%= task.id %>" type="button" class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-500 dark:text-gray-300 dark:hover:text-gray-100 transition-colors">
            Close
          </button>
          <button type="button" class="px-4 py-2.5 text-sm font-medium text-white bg-gradient-to-r <%= case task.priority
            when 'Low' then 'from-blue-500 to-cyan-500'
            when 'Medium' then 'from-yellow-500 to-amber-500'
            when 'High' then 'from-orange-500 to-red-500'
            when 'Critical' then 'from-red-500 to-pink-600'
            else 'from-indigo-500 to-purple-600'
            end %> hover:shadow-md rounded-md transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-opacity-50 <%= case task.priority
              when 'Low' then 'focus:ring-blue-500'
              when 'Medium' then 'focus:ring-yellow-500'
              when 'High' then 'focus:ring-orange-500'
              when 'Critical' then 'focus:ring-red-500'
              else 'focus:ring-indigo-500'
              end %> dark:focus:ring-offset-gray-900">
            Edit Task
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
