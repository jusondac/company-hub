<div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700 p-6">
  <!-- Board Header -->
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-gradient-to-r from-purple-500 to-pink-600 rounded-xl flex items-center justify-center shadow-lg">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
        </svg>
      </div>
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Kanban Board</h2>
        <p class="text-sm text-gray-600 dark:text-gray-400"><%= @tasks.count %> tasks across <%= @cards.count %> cards</p>
      </div>
    </div>
    <button data-modal-target="new-card-modal" data-modal-toggle="new-card-modal" 
            class="bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-semibold py-2.5 px-4 rounded-xl transition-all flex items-center text-sm shadow-lg hover:shadow-xl" type="button">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
      </svg>
      Add Card
    </button>
  </div>
  <!-- Kanban Cards Container -->
  <div class="kanban-board">
    <div data-controller="sortable"
         data-sortable-url-value="<%= sort_position_board_cards_path(@board) %>"
         data-sortable-handle-value=".drag-handle"
         data-sortable-target="list"
         class="flex gap-6 overflow-x-auto pb-4">
      <% @cards.each do |card| %>
        <div class="kanban-column min-w-[300px]" data-id="<%= card.id %>">
          <!-- Card Header -->
          <div class="kanban-column-header bg-gradient-to-r from-gray-50 to-gray-100 dark:from-gray-700 dark:to-gray-600 border border-gray-200 dark:border-gray-600" 
               style="background: linear-gradient(135deg, <%= card.color || '#6366f1' %>15 0%, <%= card.color || '#6366f1' %>05 100%);">
            <div class="flex items-center gap-3">
              <div class="drag-handle cursor-move p-1.5 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-all">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
              </div>
              <div class="w-3 h-3 rounded-full shadow-sm" style="background-color: <%= card.color || '#6366f1' %>;"></div>
              <h3 class="font-bold text-gray-900 dark:text-white flex-1"><%= card.title %></h3>
              <span class="text-xs text-gray-500 dark:text-gray-400 bg-gray-200 dark:bg-gray-700 px-2 py-1 rounded-full font-medium">
                <%= card.tasks.count %>
              </span>
            </div>
            <div class="flex items-center gap-1">
              <button data-modal-target="edit-card-modal" data-modal-toggle="edit-card-modal" 
                    data-card-id="<%= card.id %>"
                    class="p-1.5 text-gray-400 hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors rounded-lg hover:bg-emerald-100 dark:hover:bg-emerald-900/30">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
              </button>
              <button data-modal-target="delete-card-modal" data-modal-toggle="delete-card-modal" 
                    data-card-id="<%= card.id %>"
                    data-card-title="<%= card.title %>"
                    class="p-1.5 text-gray-400 hover:text-red-600 dark:hover:text-red-400 transition-colors rounded-lg hover:bg-red-100 dark:hover:bg-red-900/30">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1-1v3M4 7h16"></path>
                </svg>
              </button>
            </div>
          </div>
          <!-- Tasks Container -->
          <div class="kanban-column-content">
            <div data-kanban-target="column" 
               data-card-id="<%= card.id %>" 
               class="kanban-tasks space-y-3">
              <% card.tasks.ordered_by_position.each do |task| %>
                <div data-kanban-target="task" 
                   data-task-id="<%= task.id %>"
                   class="kanban-task-card bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 cursor-pointer hover:shadow-lg transition-all group"
                   data-modal-target="detail-modal-<%= task.id %>" 
                   data-modal-toggle="detail-modal-<%= task.id %>"
                   data-controller="task-modal"
                   data-task-modal-target="taskDetail"
                   data-task-modal-task-id=<%= task.id %>
                   data-task-modal-action="task-modal#openDetail"
                   data-task-id="<%= task.id %>">
                  <div class="flex items-start justify-between gap-3 mb-3">
                    <h4 class="kanban-task-title font-semibold text-gray-900 dark:text-white flex-1 line-clamp-2">
                      <%= task.title %>
                    </h4>
                    <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity" onclick="event.stopPropagation();">
                      <button data-modal-target="task-edit-modal" data-modal-toggle="task-edit-modal" 
                            data-task-id="<%= task.id %>"
                            class="p-1.5 text-gray-400 hover:text-amber-600 dark:hover:text-amber-400 transition-colors rounded-lg hover:bg-amber-100 dark:hover:bg-amber-900/30">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                        </svg>
                      </button>
                    </div>
                  </div>
                  <% if task.description.present? %>
                    <p class="text-gray-600 dark:text-gray-400 text-sm mb-3 line-clamp-2">
                      <%= truncate(task.description, length: 80) %>
                    </p>
                  <% end %>
                  <% if task.employees.any? %>
                    <div class="kanban-task-assignees mb-3">
                      <div class="flex items-center gap-2">
                        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                        <div class="flex -space-x-1">
                          <% task.employees.limit(3).each do |employee| %>
                            <div class="kanban-task-avatar w-6 h-6 text-xs font-bold border-2 border-white dark:border-gray-700" 
                                 style="background-color: #<%= sprintf('%06x', (employee.username.sum % 16777215)) %>;"
                                 title="<%= employee.username %>">
                              <%= employee.username.first.upcase %>
                            </div>
                          <% end %>
                          <% if task.employees.count > 3 %>
                            <div class="kanban-task-avatar w-6 h-6 text-xs font-bold bg-gray-500 border-2 border-white dark:border-gray-700">
                              +<%= task.employees.count - 3 %>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                  <div class="kanban-task-meta flex items-center justify-between">
                    <span class="kanban-task-priority px-2 py-1 rounded-lg text-xs font-medium
                      <%= case task.priority&.downcase
                          when 'critical' then 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300'
                          when 'high' then 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300'
                          when 'medium' then 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300'
                          else 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300'
                          end %>">
                      <%= task.priority || 'Low' %>
                    </span>
                    <div class="flex items-center text-xs text-gray-500 dark:text-gray-400">
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <%= time_ago_in_words(task.created_at) %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
            <!-- Add Task Button -->
            <div class="kanban-add-task mt-3">
              <button data-modal-target="new-task-modal" data-modal-toggle="new-task-modal" 
                    data-card-id="<%= card.id %>"
                    class="w-full flex items-center justify-center gap-2 p-4 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-xl transition-all text-sm border-2 border-dashed border-gray-200 dark:border-gray-600 hover:border-gray-300 dark:hover:border-gray-500 group" type="button">
                <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                <span class="font-medium">Add Task</span>
              </button>
            </div>
          </div>
        </div>
      <% end %>
      <!-- Add Card Column -->
      <div class="kanban-column min-w-[300px]">
        <button data-modal-target="new-card-modal" data-modal-toggle="new-card-modal" 
                class="w-full h-40 flex flex-col items-center justify-center gap-3 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-2xl transition-all border-2 border-dashed border-gray-300 dark:border-gray-600 hover:border-gray-400 dark:hover:border-gray-500 group" type="button">
          <div class="w-12 h-12 bg-gray-100 dark:bg-gray-700 rounded-xl flex items-center justify-center group-hover:bg-gray-200 dark:group-hover:bg-gray-600 transition-colors">
            <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
          </div>
          <span class="font-semibold">Add New Card</span>
        </button>
      </div>
    </div>
    <!-- Empty State for No Cards -->
    <% if @cards.empty? %>
      <div class="text-center py-16">
        <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-r from-blue-100 to-purple-100 dark:from-blue-900/30 dark:to-purple-900/30 rounded-2xl flex items-center justify-center">
          <svg class="w-10 h-10 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">Ready to get started?</h3>
        <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
          Create your first card to organize tasks and start managing your project efficiently.
        </p>
        <button data-modal-target="new-card-modal" data-modal-toggle="new-card-modal" 
                class="bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-semibold py-3 px-6 rounded-xl shadow-lg hover:shadow-xl transition-all inline-flex items-center" type="button">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          Create First Card
        </button>
      </div>
    <% end %>
  </div>
</div>
<!-- Task Detail Modal -->
<%= render 'boards/modals/task_detail_modal' %>
<!-- Task Detail Modal -->
<%= render 'boards/modals/task_edit_modal' %>