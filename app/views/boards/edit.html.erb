<div class="container mx-auto px-4 py-8">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center space-x-4 mb-4">
        <div class="h-10 w-10 bg-gradient-to-br from-orange-500 to-red-600 rounded-lg flex items-center justify-center">
          <svg class="h-5 w-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Edit Board</h1>
      </div>
      <p class="text-gray-600 dark:text-gray-400">Update board settings and management assignments</p>
    </div>
    <!-- Form -->
    <div class="modern-form">
      <%= form_with model: @board, local: true do |form| %>
        <!-- Error Messages -->
        <% if @board.errors.any? %>
          <div class="modern-alert modern-alert-error mb-6">
            <h3 class="font-semibold">Please fix the following errors:</h3>
            <ul class="mt-2 space-y-1">
              <% @board.errors.full_messages.each do |message| %>
                <li>• <%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <div class="modern-form-group">
          <%= form.label :name, "Board Name", class: "modern-label" %>
          <%= form.text_field :name, class: "modern-input", placeholder: "Enter board name" %>
        </div>
        <div class="modern-form-group">
          <%= form.label :description, "Description", class: "modern-label" %>
          <%= form.text_area :description, rows: 4, class: "modern-textarea", placeholder: "Describe the purpose and goals of this board" %>
        </div>
        <div class="modern-form-group">
          <label class="modern-label">Assign Managers</label>
          <div class="max-h-48 overflow-y-auto border border-gray-300 dark:border-gray-600 rounded-lg p-4 bg-gray-50 dark:bg-gray-700/50">
            <% if @employees.any? %>
              <% @employees.each do |employee| %>
                <div class="flex items-center py-2 px-3 rounded-lg hover:bg-white dark:hover:bg-gray-700 transition-colors duration-200">
                  <%= check_box_tag "board[employee_ids][]", employee.id, @board.employees.include?(employee), 
                      id: "employee_#{employee.id}", 
                      class: "rounded border-gray-300 dark:border-gray-600 text-blue-600 shadow-sm focus:border-blue-500 focus:ring-blue-500 h-4 w-4" %>
                  <%= label_tag "employee_#{employee.id}", class: "ml-3 text-sm text-gray-700 dark:text-gray-300 cursor-pointer flex-1" do %>
                    <div class="flex items-center">
                      <div class="h-8 w-8 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center text-white text-xs font-medium mr-3">
                        <%= employee.username.first.upcase %>
                      </div>
                      <div>
                        <span class="font-medium"><%= employee.username %></span>
                        <span class="text-gray-500 dark:text-gray-400"> - <%= employee.title %></span>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <p class="text-gray-500 dark:text-gray-400 text-center py-4">No employees available to assign</p>
            <% end %>
          </div>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Select employees who will manage this board and oversee its tasks</p>
        </div>
        <div class="flex justify-between pt-6">
          <%= link_to "Cancel", board_path(@board), class: "modern-btn modern-btn-secondary" %>
          <%= form.submit "Update Board", class: "modern-btn modern-btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
