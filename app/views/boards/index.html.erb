<div class="container mx-auto px-6 py-8">
  <!-- Header Section -->
  <div class="mb-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Project Boards</h1>
        <p class="text-gray-600 dark:text-gray-400">Manage your project workflows and tasks</p>
      </div>
      <%= link_to new_board_path, class: "bg-gradient-to-r from-blue-500 to-purple-600 text-white flex gap-2 px-4 py-2 rounded-lg" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Create New Board
      <% end %>
    </div>
  </div>
  <!-- Statistics Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="modern-card bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-blue-500 text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Boards</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @boards.count %></p>
        </div>
      </div>
    </div>
    <div class="modern-card bg-gradient-to-r from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-green-500 text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Total Tasks</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white"><%= @boards.sum { |board| board.tasks.count } %></p>
        </div>
      </div>
    </div>
    <div class="modern-card bg-gradient-to-r from-purple-50 to-pink-50 dark:from-purple-900/20 dark:to-pink-900/20">
      <div class="flex items-center">
        <div class="p-3 rounded-full bg-purple-500 text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <div class="ml-4">
          <p class="text-sm font-medium text-gray-600 dark:text-gray-400">Active Managers</p>
          <p class="text-2xl font-bold text-gray-900 dark:text-white">
            <%= @boards.map(&:employees).flatten.uniq.count %>
          </p>
        </div>
      </div>
    </div>
  </div>
  <!-- Boards Grid -->
  <% if @boards.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @boards.each do |board| %>
        <div class="modern-card border border-gray-700 rounded-xl hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 group">
          <!-- Board Header -->
          <div class="bg-gradient-to-r from-blue-500 to-purple-600 text-white p-6 rounded-t-xl">
            <h2 class="text-xl font-bold mb-2"><%= board.name %></h2>
            <div class="flex items-center justify-between">
              <span class="text-blue-100 text-sm">Project Board</span>
              <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <%= link_to board_path(board), class: "text-white hover:text-blue-200 transition-colors" do %>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
          <!-- Board Content -->
          <div class="p-6">
            <p class="text-gray-700 dark:text-gray-300 mb-6 leading-relaxed">
              <%= truncate(board.description, length: 120) %>
            </p>
            <!-- Managers Section -->
            <div class="mb-6">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-3 flex items-center">
                <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m3 5.197v1z"></path>
                </svg>
                Managers
              </h4>
              <% if board.employees.any? %>
                <div class="flex flex-wrap gap-2">
                  <% board.employees.limit(3).each do |employee| %>
                    <div class="modern-badge bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                      <%= employee.username %>
                    </div>
                  <% end %>
                  <% if board.employees.count > 3 %>
                    <div class="modern-badge bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">
                      +<%= board.employees.count - 3 %> more
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-gray-500 dark:text-gray-400 text-sm italic">No managers assigned</p>
              <% end %>
            </div>
            <!-- Stats -->
            <div class="flex items-center justify-between mb-6 text-sm">
              <div class="flex items-center text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                </svg>
                <span class="font-medium"><%= board.tasks.count %> Task</span>
              </div>
              <div class="flex items-center text-gray-600 dark:text-gray-400">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Updated recently
              </div>
            </div>
            <!-- Actions -->
            <div class="flex items-center justify-between pt-4 border-t border-gray-200 dark:border-gray-700">
              <%= link_to board_path(board), class: "px-2 py-1 flex gap-2 rounded-lg items-center bg-blue-800 text-white font-bold hover:bg-blue-700" do %>
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
                View Board
              <% end %>
              <div class="flex space-x-2">
                <%= link_to edit_board_path(board), class: "px-2 py-1 flex gap-2 rounded-lg items-center bg-green-800 text-white font-bold hover:bg-green-700" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                  </svg>
                  update
                <% end %>
                <%= link_to board_path(board), method: :delete, 
                            data: { confirm: "Are you sure you want to delete this board?" }, 
                            class: "px-2 py-1 flex gap-2 rounded-lg items-center bg-red-800 text-white font-bold hover:bg-red-700" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                  remove
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16">
      <div class="modern-card max-w-md mx-auto">
        <div class="p-8">
          <div class="w-16 h-16 mx-auto mb-4 bg-gradient-to-r from-blue-100 to-purple-100 dark:from-blue-900/30 dark:to-purple-900/30 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">No boards yet</h3>
          <p class="text-gray-600 dark:text-gray-400 mb-6">Create your first project board to start organizing tasks and workflows.</p>
          <%= link_to new_board_path, class: "modern-btn-primary" do %>
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Create Your First Board
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
